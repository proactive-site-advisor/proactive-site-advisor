  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Mohammad Yari",
      "email": "mohammad.yari.mail@gmail.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=7.4"
  },
  "autoload": {
    "psr-4": {
      "ProactiveSiteAdvisor\\": "src/"
    }
